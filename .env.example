# ============================================================
# Escrivão AI — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o .env com valores reais no Git.
# ============================================================

# ===== Banco de Dados (Supabase PostgreSQL) =====
DATABASE_URL=postgresql+asyncpg://postgres.SEU_PROJETO:SENHA_URL_ENCODED@aws-0-us-west-2.pooler.supabase.com:5432/postgres
DATABASE_URL_SYNC=postgresql://postgres.SEU_PROJETO:SENHA_URL_ENCODED@aws-0-us-west-2.pooler.supabase.com:5432/postgres

# ===== Supabase =====
SUPABASE_URL=https://SEU_PROJETO.supabase.co
SUPABASE_ANON_KEY=sb_publishable_XXXX
SUPABASE_SERVICE_KEY=sb_secret_XXXX
SUPABASE_STORAGE_BUCKET=inqueritos

# ===== Redis (Upstash para prod / Docker para dev) =====
REDIS_URL=redis://localhost:6379/0
# Prod (Upstash): REDIS_URL=rediss://default:SENHA@ENDPOINT.upstash.io:6380

# ===== Qdrant (Cloud para prod / Docker para dev) =====
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=escrivao_chunks
# Prod (Qdrant Cloud): QDRANT_HOST=xxxxxxxx.us-east4-0.gcp.cloud.qdrant.io

# ===== MinIO / S3 (Supabase Storage ou MinIO via Docker) =====
# Para usar Supabase Storage como backend S3, use os dados abaixo:
S3_ENDPOINT_URL=https://SEU_PROJETO.supabase.co/storage/v1/s3
S3_ACCESS_KEY=CHAVE_ACCESS_SUPABASE
S3_SECRET_KEY=CHAVE_SECRET_SUPABASE
S3_BUCKET_NAME=escrivao-documentos
# Para dev local com MinIO:
# S3_ENDPOINT_URL=http://localhost:9000
# S3_ACCESS_KEY=escrivao
# S3_SECRET_KEY=escrivao_minio_2024

# ===== LLM - Camada Econômica (DeepSeek via OpenRouter) =====
LLM_ECONOMICO_PROVIDER=openai
LLM_ECONOMICO_MODEL=deepseek/deepseek-chat
LLM_ECONOMICO_BASE_URL=https://openrouter.ai/api/v1
LLM_ECONOMICO_API_KEY=sk-or-v1-XXXX

# ===== LLM - Camada Standard (Gemini Flash) =====
LLM_STANDARD_PROVIDER=google
LLM_STANDARD_MODEL=gemini-flash-latest
LLM_STANDARD_BASE_URL=https://generativelanguage.googleapis.com
LLM_STANDARD_API_KEY=AIzaSyXXXX

# ===== LLM - Camada Premium (Gemini Pro) =====
LLM_PREMIUM_PROVIDER=google
LLM_PREMIUM_MODEL=gemini-pro-latest
LLM_PREMIUM_BASE_URL=https://generativelanguage.googleapis.com
LLM_PREMIUM_API_KEY=AIzaSyXXXX

# ===== Chaves de API =====
OPENROUTER_API_KEY=sk-or-v1-XXXX
GEMINI_API_KEY=AIzaSyXXXX
DEEPSEEK_API_KEY=sk-XXXX

# ===== Aplicação =====
APP_ENV=production
APP_SECRET_KEY=GERE-UMA-CHAVE-SEGURA-AQUI
CORS_ORIGINS=https://escrivao.vercel.app,https://*.vercel.app,http://localhost:3000
