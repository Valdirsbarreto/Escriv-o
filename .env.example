# ===== LLM - Camada Premium =====
LLM_PREMIUM_PROVIDER=openai
LLM_PREMIUM_MODEL=gpt-4.1
LLM_PREMIUM_API_KEY=sk-xxx

# ===== Aplicação =====
APP_ENV=development
APP_SECRET_KEY=troque-esta-chave-em-producao
