# ===== Banco de Dados =====
DATABASE_URL=postgresql+asyncpg://escrivao:escrivao_dev_2024@localhost:5432/escrivao_db
DATABASE_URL_SYNC=postgresql://escrivao:escrivao_dev_2024@localhost:5432/escrivao_db

# ===== Redis =====
REDIS_URL=redis://localhost:6379/0

# ===== Qdrant =====
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=escrivao_chunks

# ===== MinIO / S3 =====
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=escrivao
S3_SECRET_KEY=escrivao_minio_2024
S3_BUCKET_NAME=escrivao-documentos

# ===== LLM - Camada Econômica =====
LLM_ECONOMICO_PROVIDER=openai
LLM_ECONOMICO_MODEL=gpt-4.1-nano
